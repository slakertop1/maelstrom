{
  "name": "mock-service",
  "duration_secs": 20,
  "timeout_ms": 5000,
  "datasets": [
    { "name": "people", "mode": "sequential", "source": { "kind": "file", "path": "people.csv" } }
  ],
  "targets": [
    { "name": "hello",   "method": "GET", "url": "http://127.0.0.1:8900/api/hello", "rps": 50 },
    { "name": "slow",    "method": "GET", "url": "http://127.0.0.1:8900/api/slow",  "rps": 30 },
    { "name": "flaky",   "method": "GET", "url": "http://127.0.0.1:8900/api/flaky", "rps": 20 },
    { "name": "echo",    "method": "GET",
      "url": "http://127.0.0.1:8900/api/echo?id={{$counter}}&r={{$randomInt(1,100)}}&u={{$uuid}}&who={{$data.people.name}}",
      "rps": 25 },
    { "name": "protected", "method": "GET", "url": "http://127.0.0.1:8900/api/protected", "rps": 25,
      "auth_refresh": { "grant_type": "client_credentials", "token_url": "http://127.0.0.1:8900/oauth/token",
                        "client_id": "svc", "client_secret": "${OAUTH_CLIENT_SECRET}", "client_auth": "body" } }
  ],
  "thresholds": { "max_error_rate": 3.0, "max_p95_ms": 500 }
}
